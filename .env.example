# Cloud backend (server-side only)
INTOPIA_BACKEND=supabase
APP_ENV=development
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SECRET_KEY=PASTE_THE_SERVER_SECRET_KEY_HERE
SUPABASE_BUCKET=intopia-files

# Shared-link protection. Use a strong password in Render.
APP_REQUIRE_AUTH=true
APP_ACCESS_USER=intopia
APP_ACCESS_PASSWORD=CHANGE_ME

# Upload and restore limits
MAX_UPLOAD_MB=10
MAX_RESTORE_MB=100

# Optional Decision Agent. Keep the API key only on the server.
OPENAI_AGENT_ENABLED=true
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-sol
OPENAI_MAX_OUTPUT_TOKENS=2400
